# This file is generated by CMake.
# It is the entry point for `find_package(PACKAGE_NAME)`.
#
# When a consumer project calls `find_package(PACKAGE_NAME)`, this file is executed.
# Its purpose is to ensure that all of `PACKAGE_NAME`'s public dependencies are also
# found and configured in the consumer's environment, and then to expose
# `PACKAGE_NAME`'s own targets and properties.

@PACKAGE_INIT@

# Retrieve the list of dependency specifications passed from the main CMakeLists.txt.
# This variable was set in `configure_package_config_file` call.
# Example content: "Eigen3;fmt REQUIRED;Boost COMPONENTS regex"
set(GENERATED_DEPENDENCIES_LIST "@GENERATED_DEPENDENCIES@")

# Convert the semicolon-separated list of dependency specifications into
# a proper CMake list where each item is a single dependency specification string.
# We replace semicolons with newlines to allow FOREACH to iterate over multi-word items.
# string(REPLACE ";" "\n" GENERATED_DEPENDENCIES_LIST "${GENERATED_DEPENDENCIES_RAW_LIST}")

# Iterate through each dependency specification and call find_dependency for it.
foreach(DEP_SPEC ${GENERATED_DEPENDENCIES_LIST})
    # Split DEP_SPEC into the package name and its remaining arguments.
    # Regex: captures the first word (package name) and the rest into two groups.
    string(REGEX MATCH "^([A-Za-z0-9_.-]+)(.*)" _match_result "${DEP_SPEC}")
    set(_package_name "${CMAKE_MATCH_1}") # This is the actual package name (e.g., "Eigen3", "Boost")
    set(_package_args "${CMAKE_MATCH_2}") # This is the rest of the arguments (e.g., " REQUIRED", " COMPONENTS regex")
    set(_package_args_list "")

    # Clean up _package_args: remove any leading space if arguments exist.
    string(REGEX REPLACE "^ " "" _package_args "${_package_args}")

    if (_package_args) # Only check if _package_args is not empty
        # Convert _package_args string to a list of parts to iterate.
        string(REPLACE " " ";" _package_args_list "${_package_args}")
    endif()

    find_package(${_package_name} ${_package_args_list})
endforeach()

include("${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@Targets.cmake")


# Any further setup required for consumers of 'PACKAGE_NAME' can be added here.
# For example, if you need to define custom variables or functions for consumers.